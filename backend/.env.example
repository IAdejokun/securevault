DATABASE_URL=postgresql://postgres:password@localhost:5432/securevault
JWT_SECRET_KEY=change_this_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
NONCE_WINDOW_SECONDS=30
APP_ENV=development
CORS_ORIGINS=http://localhost:4200,http://localhost:3000
ANOMALY_MODEL_PATH=models/isolation_forest.joblib
ANOMALY_SCORE_THRESHOLD=75